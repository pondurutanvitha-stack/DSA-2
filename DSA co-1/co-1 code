import java.util.*;

public class PatientIndexingBSTAVL {

    // ---------- BST NODE ----------
    static class BSTNode {
        int key;
        BSTNode left, right;

        BSTNode(int key) {
            this.key = key;
        }
    }

    // ---------- AVL NODE ----------
    static class AVLNode {
        int key, height;
        AVLNode left, right;

        AVLNode(int key) {
            this.key = key;
            this.height = 0; // height in edges
        }
    }

    // ---------- BST METHODS ----------
    static BSTNode bstInsert(BSTNode root, int key) {
        if (root == null) return new BSTNode(key);

        if (key < root.key) root.left = bstInsert(root.left, key);
        else if (key > root.key) root.right = bstInsert(root.right, key);

        return root;
    }

    static BSTNode bstDelete(BSTNode root, int key) {
        if (root == null) return null;

        if (key < root.key) {
            root.left = bstDelete(root.left, key);
        } else if (key > root.key) {
            root.right = bstDelete(root.right, key);
        } else {
            if (root.left == null) return root.right;
            if (root.right == null) return root.left;

            BSTNode succ = minBST(root.right);
            root.key = succ.key;
            root.right = bstDelete(root.right, succ.key);
        }
        return root;
    }

    static BSTNode minBST(BSTNode node) {
        while (node.left != null) node = node.left;
        return node;
    }

    static boolean bstSearch(BSTNode root, int key) {
        if (root == null) return false;
        if (root.key == key) return true;
        if (key < root.key) return bstSearch(root.left, key);
        return bstSearch(root.right, key);
    }

    static void bstInorder(BSTNode root, StringBuilder sb) {
        if (root != null) {
            bstInorder(root.left, sb);
            sb.append(root.key).append(" ");
            bstInorder(root.right, sb);
        }
    }

    static int bstHeight(BSTNode root) {
        if (root == null) return -1; // height in edges
        return 1 + Math.max(bstHeight(root.left), bstHeight(root.right));
    }

    // ---------- AVL METHODS ----------
    static int avlHeight(AVLNode node) {
        return (node == null) ? -1 : node.height;
    }

    static int balanceFactor(AVLNode node) {
        return (node == null) ? 0 : avlHeight(node.left) - avlHeight(node.right);
    }

    static AVLNode rightRotate(AVLNode y) {
        AVLNode x = y.left;
        AVLNode t2 = x.right;

        x.right = y;
        y.left = t2;

        y.height = 1 + Math.max(avlHeight(y.left), avlHeight(y.right));
        x.height = 1 + Math.max(avlHeight(x.left), avlHeight(x.right));

        return x;
    }

    static AVLNode leftRotate(AVLNode x) {
        AVLNode y = x.right;
        AVLNode t2 = y.left;

        y.left = x;
        x.right = t2;

        x.height = 1 + Math.max(avlHeight(x.left), avlHeight(x.right));
        y.height = 1 + Math.max(avlHeight(y.left), avlHeight(y.right));

        return y;
    }

    static AVLNode avlInsert(AVLNode node, int key) {
        if (node == null) return new AVLNode(key);

        if (key < node.key) node.left = avlInsert(node.left, key);
        else if (key > node.key) node.right = avlInsert(node.right, key);
        else return node;

        node.height = 1 + Math.max(avlHeight(node.left), avlHeight(node.right));
        int bf = balanceFactor(node);

        // LL
        if (bf > 1 && key < node.left.key) return rightRotate(node);

        // RR
        if (bf < -1 && key > node.right.key) return leftRotate(node);

        // LR
        if (bf > 1 && key > node.left.key) {
            node.left = leftRotate(node.left);
            return rightRotate(node);
        }

        // RL
        if (bf < -1 && key < node.right.key) {
            node.right = rightRotate(node.right);
            return leftRotate(node);
        }

        return node;
    }

    static AVLNode minAVL(AVLNode node) {
        while (node.left != null) node = node.left;
        return node;
    }

    static AVLNode avlDelete(AVLNode root, int key) {
        if (root == null) return null;

        if (key < root.key) {
            root.left = avlDelete(root.left, key);
        } else if (key > root.key) {
            root.right = avlDelete(root.right, key);
        } else {
            if (root.left == null || root.right == null) {
                AVLNode temp = (root.left != null) ? root.left : root.right;
                root = temp;
            } else {
                AVLNode temp = minAVL(root.right);
                root.key = temp.key;
                root.right = avlDelete(root.right, temp.key);
            }
        }

        if (root == null) return null;

        root.height = 1 + Math.max(avlHeight(root.left), avlHeight(root.right));
        int bf = balanceFactor(root);

        // LL
        if (bf > 1 && balanceFactor(root.left) >= 0) return rightRotate(root);

        // LR
        if (bf > 1 && balanceFactor(root.left) < 0) {
            root.left = leftRotate(root.left);
            return rightRotate(root);
        }

        // RR
        if (bf < -1 && balanceFactor(root.right) <= 0) return leftRotate(root);

        // RL
        if (bf < -1 && balanceFactor(root.right) > 0) {
            root.right = rightRotate(root.right);
            return leftRotate(root);
        }

        return root;
    }

    static boolean avlSearch(AVLNode root, int key) {
        if (root == null) return false;
        if (root.key == key) return true;
        if (key < root.key) return avlSearch(root.left, key);
        return avlSearch(root.right, key);
    }

    static void avlInorder(AVLNode root, StringBuilder sb) {
        if (root != null) {
            avlInorder(root.left, sb);
            sb.append(root.key).append(" ");
            avlInorder(root.right, sb);
        }
    }

    // ---------- MAIN ----------
    public static void main(String[] args) {
        int[] patientIds = {20, 30, 35, 40, 45, 50, 60, 65, 70, 75, 80, 85, 90};

        BSTNode bstRoot = null;
        AVLNode avlRoot = null;

        for (int id : patientIds) {
            bstRoot = bstInsert(bstRoot, id);
            avlRoot = avlInsert(avlRoot, id);
        }

        System.out.println("=== MEDIFLOW HOSPITAL PATIENT INDEXING ===");
        System.out.print("Patient IDs Inserted: ");
        for (int id : patientIds) System.out.print(id + " ");
        System.out.println();

        StringBuilder bstOrder = new StringBuilder();
        bstInorder(bstRoot, bstOrder);
        System.out.println("BST Inorder Traversal:");
        System.out.println(bstOrder.toString().trim());
        System.out.println("BST Height (edges): " + bstHeight(bstRoot));

        int search1 = 60;
        int search2 = 55;
        System.out.println("Search " + search1 + " in BST: " + (bstSearch(bstRoot, search1) ? "Found" : "Not Found"));
        System.out.println("Search " + search2 + " in BST: " + (bstSearch(bstRoot, search2) ? "Found" : "Not Found"));

        bstRoot = bstDelete(bstRoot, 30);
        bstRoot = bstDelete(bstRoot, 70);

        bstOrder.setLength(0);
        bstInorder(bstRoot, bstOrder);
        System.out.println("BST Inorder After Deletions: " + bstOrder.toString().trim());

        System.out.println();

        StringBuilder avlOrder = new StringBuilder();
        avlInorder(avlRoot, avlOrder);
        System.out.println("AVL Inorder Traversal:");
        System.out.println(avlOrder.toString().trim());
        System.out.println("AVL Height (edges): " + avlHeight(avlRoot));
        System.out.println("Search " + search1 + " in AVL: " + (avlSearch(avlRoot, search1) ? "Found" : "Not Found"));
        System.out.println("Search " + search2 + " in AVL: " + (avlSearch(avlRoot, search2) ? "Found" : "Not Found"));

        avlRoot = avlDelete(avlRoot, 30);
        avlRoot = avlDelete(avlRoot, 70);

        avlOrder.setLength(0);
        avlInorder(avlRoot, avlOrder);
        System.out.println("AVL Inorder After Deletions: " + avlOrder.toString().trim());

        System.out.println();
        System.out.println("Performance Comparison:");
        System.out.println("BST Height  = " + bstHeight(bstRoot));
        System.out.println("AVL Height  = " + avlHeight(avlRoot));
        System.out.println("Observation: AVL Tree maintains balanced structure and provides O(log n) performance.");
    }
}
